alias c="clear"
alias ls="eza"
alias v="nvim"

export EDITOR="hx"
export COLORTERM=truecolor

setopt PROMPT_SUBST

parse_git_status() {
  local clean_fg="$1" dirty_fg="$2"
  local git_branch git_status
  git_branch="$(git symbolic-ref --short HEAD 2>/dev/null)" \
    || git_branch="$(git rev-parse --short HEAD 2>/dev/null)"
  [[ -z "$git_branch" ]] && return

  git_status="$(git status --porcelain 2>/dev/null)"
  if [[ -n "$git_status" ]]; then
    echo " %F{$dirty_fg}${git_branch}*%f"
  else
    echo " %F{$clean_fg}${git_branch}%f"
  fi
}

PROMPT='%F{cyan}%n%f in %F{white}%1~%f$(parse_git_status green yellow) %F{cyan}$%f '
unset RPROMPT

# Shell completion init
autoload -Uz compinit
compinit

# Zoxide
eval "$(zoxide init zsh)"

### Added by Zinit's installer
if [[ ! -f $HOME/.local/share/zinit/zinit.git/zinit.zsh ]]; then
    print -P "%F{33} %F{220}Installing %F{33}ZDHARMA-CONTINUUM%F{220} Initiative Plugin Manager (%F{33}zdharma-continuum/zinit%F{220})…%f"
    command mkdir -p "$HOME/.local/share/zinit" && command chmod g-rwX "$HOME/.local/share/zinit"
    command git clone https://github.com/zdharma-continuum/zinit "$HOME/.local/share/zinit/zinit.git" && \
        print -P "%F{33} %F{34}Installation successful.%f%b" || \
        print -P "%F{160} The clone has failed.%f%b"
fi

source "$HOME/.local/share/zinit/zinit.git/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit
### End of Zinit's installer chunk

[[ $- != *i* ]] && return
[[ -n "$NVIM" ]] && return

# Tell dotenv to automatically load
export ZSH_DOTENV_PROMPT=false

# Steal the dotenv plugin directly from Oh-My-Zsh
zinit snippet OMZP::dotenv

# Grab the supercharged vi-mode from GitHub
zinit light jeffreytse/zsh-vi-mode

# Get your syntax highlighting and autosuggestions
zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-syntax-highlighting

# Load Nanobrew Binaries
export PATH="/opt/nanobrew/prefix/bin:$PATH"
